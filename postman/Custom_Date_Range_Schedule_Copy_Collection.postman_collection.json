{
	"info": {
		"_postman_id": "custom-date-range-schedule-copy-collection",
		"name": "Custom Date Range Schedule Copy API",
		"description": "Comprehensive collection for testing the Custom Date Range Schedule Copy functionality. This collection includes all endpoints for copying doctor schedules from custom date ranges to target date ranges.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "custom-date-range-schedule-copy"
	},
	"item": [
		{
			"name": "Doctor Convenience Endpoint",
			"item": [
				{
					"name": "Copy My Schedule from Date Range (Doctor)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{doctor_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sourceStartDate\": \"2024-01-21\",\n  \"sourceEndDate\": \"2024-01-27\",\n  \"targetStartDate\": \"2024-01-28\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/doctors/schedule/copy-date-range",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"doctors",
								"schedule",
								"copy-date-range"
							]
						},
						"description": "Simple endpoint for doctors to copy their own schedule from a custom date range to a target date range. Uses authenticated user's ID."
					},
					"response": []
				},
				{
					"name": "Copy Another Doctor's Schedule from Date Range (Admin)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sourceStartDate\": \"2024-01-21\",\n  \"sourceEndDate\": \"2024-01-24\",\n  \"targetStartDate\": \"2024-01-27\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/doctors/schedule/copy-date-range?doctorId={{test_doctor_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"doctors",
								"schedule",
								"copy-date-range"
							],
							"query": [
								{
									"key": "doctorId",
									"value": "{{test_doctor_id}}"
								}
							]
						},
						"description": "Admin can copy any doctor's schedule from a custom date range to a target date range. Uses query parameter for doctor ID."
					},
					"response": []
				}
			],
			"description": "Simple convenience endpoints for doctors to copy their own schedules from custom date ranges. No path parameters needed - uses authenticated user's ID."
		},
