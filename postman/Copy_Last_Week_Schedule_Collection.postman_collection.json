	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-calculate dates for testing",
					"const now = new Date();",
					"",
					"// Current week (Monday to Sunday)",
					"const currentWeekStart = new Date(now);",
					"currentWeekStart.setDate(now.getDate() - now.getDay() + 1); // Monday",
					"const currentWeekEnd = new Date(currentWeekStart);",
					"currentWeekEnd.setDate(currentWeekStart.getDate() + 6); // Sunday",
					"",
					"// Next week Monday",
					"const nextWeekMonday = new Date(currentWeekStart);",
					"nextWeekMonday.setDate(currentWeekStart.getDate() + 7);",
					"",
					"// Format dates as YYYY-MM-DD",
					"pm.environment.set('current_week_start', currentWeekStart.toISOString().split('T')[0]);",
					"pm.environment.set('current_week_end', currentWeekEnd.toISOString().split('T')[0]);",
					"pm.environment.set('next_week_monday', nextWeekMonday.toISOString().split('T')[0]);",
					"",
					"console.log('Current week start:', pm.environment.get('current_week_start'));",
					"console.log('Current week end:', pm.environment.get('current_week_end'));",
					"console.log('Next week Monday:', pm.environment.get('next_week_monday'));"
				]
			}
		}
	],
