							]
						},
						"description": "Advanced endpoint to copy a doctor's schedule from last week to current week. Uses path parameter for doctor ID."
					},
					"response": []
				},
				{
					"name": "Copy to Specific Target Week",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"targetWeekStart\": \"{{next_week_monday}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/schedule/copy-last-week/{{test_doctor_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"schedule",
								"copy-last-week",
								"{{test_doctor_id}}"
							]
						},
						"description": "Copy schedule to a specific target week instead of current week. The targetWeekStart should be a Monday date."
					},
					"response": []
				}
			],
			"description": "Advanced endpoints with more options for copying schedules, including target week specification."
		},
