{
	"info": {
		"_postman_id": "copy-last-week-schedule-collection",
		"name": "Copy Last Week Schedule API",
		"description": "Comprehensive collection for testing the Copy Last Week Schedule functionality. This collection includes all endpoints for copying doctor schedules from the previous week to the current week.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "copy-last-week-schedule"
	},
	"item": [
		{
			"name": "Doctor Convenience Endpoint",
			"item": [
				{
					"name": "Copy My Schedule (Doctor)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{doctor_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": ""
						},
						"url": {
							"raw": "{{base_url}}/api/doctors/schedule/copy-last-week",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"doctors",
								"schedule",
								"copy-last-week"
							]
						},
						"description": "Simple endpoint for doctors to copy their own schedule from last week to current week. No request body needed - uses authenticated user's ID."
					},
					"response": []
				},
				{
					"name": "Copy Specific Doctor Schedule (Admin)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": ""
						},
						"url": {
							"raw": "{{base_url}}/api/doctors/schedule/copy-last-week?doctorId={{test_doctor_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"doctors",
								"schedule",
								"copy-last-week"
							],
							"query": [
								{
									"key": "doctorId",
									"value": "{{test_doctor_id}}",
									"description": "ID of the doctor whose schedule to copy"
								}
							]
						},
						"description": "Admin can copy any doctor's schedule by specifying the doctorId query parameter."
					},
					"response": []
				}
			],
			"description": "Simple endpoints for doctors to copy their own schedules. These endpoints automatically use the authenticated user's ID."
		},
