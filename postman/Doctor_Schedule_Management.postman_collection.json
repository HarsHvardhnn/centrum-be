								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"doctorId\": \"{{doctor_id}}\",\n  \"startDate\": \"2024-01-15\",\n  \"endDate\": \"2024-01-21\",\n  \"weeklyPattern\": {\n    \"monday\": {\n      \"timeBlocks\": [\n        {\"startTime\": \"09:00\", \"endTime\": \"12:00\", \"isActive\": true},\n        {\"startTime\": \"14:00\", \"endTime\": \"18:00\", \"isActive\": true}\n      ]\n    },\n    \"tuesday\": {\n      \"timeBlocks\": [\n        {\"startTime\": \"09:00\", \"endTime\": \"12:00\", \"isActive\": true},\n        {\"startTime\": \"14:00\", \"endTime\": \"18:00\", \"isActive\": true}\n      ]\n    },\n    \"wednesday\": {\n      \"timeBlocks\": [\n        {\"startTime\": \"09:00\", \"endTime\": \"12:00\", \"isActive\": true}\n      ]\n    },\n    \"thursday\": {\n      \"timeBlocks\": [\n        {\"startTime\": \"09:00\", \"endTime\": \"12:00\", \"isActive\": true},\n        {\"startTime\": \"14:00\", \"endTime\": \"18:00\", \"isActive\": true}\n      ]\n    },\n    \"friday\": {\n      \"timeBlocks\": [\n        {\"startTime\": \"09:00\", \"endTime\": \"12:00\", \"isActive\": true}\n      ]\n    },\n    \"saturday\": {\n      \"timeBlocks\": []\n    },\n    \"sunday\": {\n      \"timeBlocks\": []\n    }\n  },\n  \"notes\": \"Weekly schedule for January 15-21, 2024\"\n}"
						},
