							"raw": "{\n  \"doctorId\": \"{{doctor_id}}\",\n  \"date\": \"2024-01-15\",\n  \"timeBlocks\": [\n    {\n      \"startTime\": \"09:00\",\n      \"endTime\": \"12:00\",\n      \"isActive\": true\n    },\n    {\n      \"startTime\": \"14:00\",\n      \"endTime\": \"18:00\",\n      \"isActive\": true\n    }\n  ],\n  \"isActive\": true,\n  \"notes\": \"Regular Monday schedule\"\n}"
